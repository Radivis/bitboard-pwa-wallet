{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases (no baseUrl — TS 6 deprecates baseUrl used only to prefix paths) */
    "paths": {
      "@/*": ["./src/*"],
      "@common/*": ["./common/*"],
      "@legal-entity-fields": ["./src/components/LegalEntityFields.tsx"],
      "@legal-entity": ["./src/legal-entity/legal-entity.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "common/**/*.ts", "common/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.spec.ts", "src/**/*.spec.tsx", "src/test-utils"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
