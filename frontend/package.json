{
  "name": "bitboard-pwa-wallet",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc && vite build",
    "build:wasm": "cd ../crypto && wasm-pack build --target bundler --out-dir ../frontend/src/wasm-pkg && cd ../bitboard-encryption && wasm-pack build --target bundler --out-dir ../frontend/src/wasm-pkg/bitboard_encryption && cd ../bitboard-lightning && wasm-pack build --target bundler --out-dir ../frontend/src/wasm-pkg/bitboard_lightning",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:testnet-live": "playwright test tests/e2e/testnet-funded-wallet-network-switch.spec.ts",
    "test:e2e:headed": "HEADED=true playwright test",
    "test:e2e:sequential": "E2E_SEQUENTIAL=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:nwc": "VITE_E2E_NWC_MOCK=true playwright test --grep @nwc",
    "test:regtest:start": "../scripts/start-regtest.sh",
    "test:regtest:stop": "docker rm -f bitboard-regtest",
    "test:e2e:regtest": "npm run test:regtest:start && playwright test --grep @regtest",
    "test:e2e:lab": "playwright test --grep @lab",
    "sync-version": "node ../scripts/sync-version.mjs",
    "verify-version": "node ../scripts/verify-version.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@getalby/sdk": "7.0.0",
    "@subframe7536/sqlite-wasm": "1.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-router": "1.168.22",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "comlink": "4.4.2",
    "date-fns": "4.1.0",
    "jszip": "3.10.1",
    "katex": "0.16.45",
    "kysely": "0.28.16",
    "kysely-wasqlite-worker": "1.2.1",
    "lucide-react": "1.8.0",
    "qr-scanner": "1.4.2",
    "qrcode.react": "4.2.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-katex": "3.1.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-wasm": "3.6.0",
    "zustand": "5.0.12",
    "zxcvbn": "4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/router-plugin": "1.167.22",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-katex": "3.0.4",
    "@types/zxcvbn": "4.4.5",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "better-sqlite3": "12.9.0",
    "dotenv": "^17.4.2",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "fake-indexeddb": "6.2.5",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "shadcn": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
