{
  "name": "bitboard-pwa-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc && vite build",
    "build:wasm": "cd ../crypto && wasm-pack build --target bundler --out-dir ../frontend/src/wasm-pkg && cd ../bitboard-encryption && wasm-pack build --target bundler --out-dir ../frontend/src/wasm-pkg/bitboard_encryption",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "HEADED=true playwright test",
    "test:e2e:sequential": "E2E_SEQUENTIAL=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:regtest:start": "../scripts/start-regtest.sh",
    "test:regtest:stop": "docker rm -f bitboard-regtest",
    "test:e2e:regtest": "npm run test:regtest:start && playwright test --grep @regtest",
    "test:e2e:lab": "playwright test --grep @lab"
  },
  "dependencies": {
    "@subframe7536/sqlite-wasm": "^0.5.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.11",
    "kysely-wasqlite-worker": "^1.2.1",
    "lucide-react": "^0.576.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.5.0",
    "zustand": "^5.0.11",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/router-plugin": "^1.164.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "better-sqlite3": "^12.6.2",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.26",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "24.1.3",
    "playwright": "1.58.2",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
