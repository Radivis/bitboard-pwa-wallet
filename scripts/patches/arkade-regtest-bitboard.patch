-// Run a command inside a container by name: `docker exec <container> <argv...>`.
-export function dockerExec(container, argv, opts = {}) {
-  return docker(['exec', container, ...argv], opts);
+// Run a command inside a container by logical name: `docker exec <container> <argv...>`.
+// When ARKADE_REGTEST_CONTAINER_PREFIX is set (Bitboard .env.regtest), matches
+// docker/arkade-regtest.override.yml container_name values.
+export function resolveContainerName(logicalName) {
+  const prefix = process.env.ARKADE_REGTEST_CONTAINER_PREFIX || '';
+  return `${prefix}${logicalName}`;
+}
+
+export function dockerExec(logicalContainer, argv, opts = {}) {
+  return docker(['exec', resolveContainerName(logicalContainer), ...argv], opts);
 }
