+function walletAlreadyExistsError(result) {
+  const detail = `${result.stderr || ''} ${result.stdout || ''}`.toLowerCase();
+  return detail.includes('already exists') || detail.includes('database already exists');
+}
+
+/** Load the node wallet after restart when wallet files exist on disk but are not loaded. */
+function ensureBitcoinWalletLoaded() {
+  if (loadedWalletCount() > 0) return true;
+
+  const createResult = bitcoinCli(['createwallet', WALLET], { capture: true });
+  if (loadedWalletCount() > 0) return true;
+
+  if (walletAlreadyExistsError(createResult)) {
+    const loadResult = bitcoinCli(['loadwallet', WALLET], { capture: true });
+    if (loadResult.code === 0 && loadedWalletCount() > 0) return true;
+    warn(`loadwallet ${WALLET} failed: ${loadResult.stderr || loadResult.stdout}`);
+  } else if (createResult.code !== 0) {
+    warn(`createwallet ${WALLET} failed: ${createResult.stderr || createResult.stdout}`);
+  }
+
+  return loadedWalletCount() > 0;
+}
+
 export function bitcoinCli(args, opts = {}) {
   return dockerExec('bitcoin', [...CLI, ...args], opts);
 }
