# Copy to `.env.legal-notice.en` at the repository root (gitignored).
# Build injects `VITE_LEGAL_NOTICE_EN` via `load-vite-env.mjs`.

# Plain text. Use \n for line breaks, or double-quoted multiline (dotenv).

VITE_LEGAL_NOTICE_EN="Legal notice (example — replace in your local .env.legal-notice.en)\n\nProvider: …\nAddress: …\nContact: …"
