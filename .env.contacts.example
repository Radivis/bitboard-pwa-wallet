# Copy this file to `.env.contacts` at the repository root (same directory as this example).
# `.env.contacts` is gitignored — use it for optional developer / feedback contact lines on machines
# and in CI that deploy production PWA builds.
#
# The PWA (`frontend/`) reads this file at build time via `load-vite-env.mjs` and injects
# `VITE_CONTACTS` into the client bundle (Settings → Developer contact card).
#
# Production: ensure `.env.contacts` exists before `npm run build` (or set the same value in your
# CI secrets and write it to that file in the build step).

# Plain text. Use \n for line breaks in a single line, or use double-quoted multiline (dotenv).

VITE_CONTACTS="E-Mail: dev@example.org\nX: @ExampleHandle\nTelegram: @ExampleHandle\nNostr: https://njump.me/npub1example…"
